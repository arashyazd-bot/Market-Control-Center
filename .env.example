# Free FRED API key — get one instantly at https://fredaccount.stlouisfed.org/apikeys
# The dashboard runs without it (on bundled sample data), but live macro/rates
# data requires this key.
FRED_API_KEY=

# Optional: Financial Modeling Prep (FMP) key — https://financialmodelingprep.com
# When set, FMP takes priority over FRED for rates/macro (treasury curve, GDP,
# CPI, unemployment, fed funds, consumer sentiment, claims, mortgage rates,
# recession probability, sector performance, economic calendar). Falls back to
# FRED, then sample. Some endpoints (calendar, index/commodity quotes) need a
# paid FMP tier; the app degrades gracefully.
FMP_API_KEY=
